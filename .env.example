# Copy this file to .env and fill in real values. Never commit .env.

# --- BUNQ (sandbox) ---
# See BUNQ_INTEGRATION.md. Sandbox base URL is fixed.
BUNQ_API_BASE=https://public-api.sandbox.bunq.com

# --- Supabase (per-user state, wishlist, price history) ---
# Postgres connection string from Supabase project settings →
# Database → Connection string → Transaction pooler. Port 6543.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# Optional, only needed if you use the Supabase REST API (we use direct Postgres):
SUPABASE_URL=
SUPABASE_KEY=

# --- Image pipeline ---
# ImgBB: public image hosting so SerpApi can read them.
IMGBB_KEY=
# SerpApi: Google Lens product search (country=nl).
SERPAPI_KEY=

# --- AI ---
# Anthropic Claude — plain-language purchase reasoning.
ANTHROPIC_API_KEY=

# --- Telegram ---
# Bot token from @BotFather.
TELEGRAM_BOT_TOKEN=

# --- Frontend ---
# URL the Vite build should call for the API. For local dev usually http://localhost:8000.
VITE_API_BASE_URL=http://localhost:8000
